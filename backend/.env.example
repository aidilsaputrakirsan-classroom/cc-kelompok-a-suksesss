# ---------------------------------------------------------
# ENVIRONMENT CONFIGURATION TEMPLATE
# ---------------------------------------------------------
# Buat file .env dari sini, lalu sesuaikan isinya:
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)
#
# file .env JANGAN DICOMMIT ke Git!
# ---------------------------------------------------------

# --- Database (Ubah YOURPASSWORD dengan password PostgreSQL Anda) ---
DATABASE_URL=postgresql://postgres:yourpassword@host.docker.internal:5432/cloudapp

# --- App Settings ---
APP_ENV=development
DEBUG=true

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT Authentication
SECRET_KEY=ganti_dengan_kunci_rahasia_anda_sendiri
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT
SECRET_KEY=your-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173